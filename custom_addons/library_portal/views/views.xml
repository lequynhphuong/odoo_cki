<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions -->
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Library Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_library_borrow_request" model="ir.actions.act_window">
        <field name="name">Borrow Requests</field>
        <field name="res_model">library.borrow.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_library_root" name="Library Portal" sequence="10"/>

    <menuitem id="menu_library_books" name="Books" parent="menu_library_root" action="action_library_book" sequence="1"/>

    <menuitem id="menu_library_borrow_requests" name="Borrow Requests" parent="menu_library_root" action="action_library_borrow_request" sequence="2"/>

    <!-- List Views -->
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="quantity"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_library_borrow_request_tree" model="ir.ui.view">
        <field name="name">library.borrow.request.list</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="book_id"/>
                <field name="request_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form Views -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="author"/>
                        <field name="isbn"/>
                        <field name="quantity"/>
                        <field name="state"/>
                        <field name="description"/>
                        <field name="image" widget="image"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_library_borrow_request_form" model="ir.ui.view">
        <field name="name">library.borrow.request.form</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="book_id"/>
                        <field name="request_date"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>