<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="library_portal.book_list" name="Book List">
        <t t-call="website.layout">
            <div class="container">
                <h1>Danh sách sách</h1>
                <div class="row">
                    <t t-foreach="books" t-as="book">
                        <div class="col-md-4 mb-4">
                            <div class="card">
                                <t t-if="book.image">
                                    <img t-attf-src="data:image/png;base64,{{book.image}}" class="card-img-top" alt="Book Image"/>
                                </t>
                                <div class="card-body">
                                    <h5 class="card-title"><t t-esc="book.name"/></h5>
                                    <p class="card-text">Tác giả: <t t-esc="book.author"/></p>
                                    <p class="card-text">ISBN: <t t-esc="book.isbn"/></p>
                                    <p class="card-text">Số lượng còn: <t t-esc="book.quantity"/></p>
                                    <a t-attf-href="/library/book/{{book.id}}" class="btn btn-primary">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <template id="library_portal.book_detail" name="Book Detail">
        <t t-call="website.layout">
            <div class="container">
                <h1><t t-esc="book.name"/></h1>
                <div class="row">
                    <div class="col-md-4">
                        <t t-if="book.image">
                            <img t-attf-src="data:image/png;base64,{{book.image}}" class="img-fluid" alt="Book Image"/>
                        </t>
                    </div>
                    <div class="col-md-8">
                        <p><strong>Tác giả:</strong> <t t-esc="book.author"/></p>
                        <p><strong>ISBN:</strong> <t t-esc="book.isbn"/></p>
                        <p><strong>Số lượng còn:</strong> <t t-esc="book.quantity"/></p>
                        <p><strong>Mô tả:</strong> <t t-esc="book.description"/></p>
                        <p><strong>Trạng thái:</strong> <t t-esc="book.state"/></p>
                        <a t-attf-href="/library/borrow/{{book.id}}" class="btn btn-success">Đăng ký mượn</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="library_portal.borrow_form" name="Borrow Form">
        <t t-call="website.layout">
            <div class="container">
                <h1>Đăng ký mượn sách: <t t-esc="book.name"/></h1>
                <form action="/library/borrow/submit" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="book_id" t-att-value="book.id"/>
                    <div class="form-group">
                        <label for="name">Tên người mượn</label>
                        <input type="text" class="form-control" id="name" name="name" t-att-value="values.get('name', '')" required="required"/>
                        <t t-if="errors.get('name')">
                            <div class="text-danger"><t t-esc="errors['name']"/></div>
                        </t>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" class="form-control" id="email" name="email" t-att-value="values.get('email', '')" required="required"/>
                        <t t-if="errors.get('email')">
                            <div class="text-danger"><t t-esc="errors['email']"/></div>
                        </t>
                    </div>
                    <div class="form-group">
                        <label for="phone">Số điện thoại</label>
                        <input type="text" class="form-control" id="phone" name="phone" t-att-value="values.get('phone', '')"/>
                    </div>
                    <button type="submit" class="btn btn-primary">Gửi đăng ký</button>
                </form>
            </div>
        </t>
    </template>

    <template id="library_portal.thank_you" name="Thank You">
        <t t-call="website.layout">
            <div class="container">
                <h1>Cảm ơn bạn đã đăng ký mượn sách!</h1>
                <p>Yêu cầu của bạn đã được gửi thành công.</p>
                <p><strong>Tên sách:</strong> <t t-esc="borrow_request.book_id.name"/></p>
                <p><strong>Tên người mượn:</strong> <t t-esc="borrow_request.name"/></p>
                <p><strong>Email:</strong> <t t-esc="borrow_request.email"/></p>
                <p><strong>Ngày yêu cầu:</strong> <t t-esc="borrow_request.request_date"/></p>
                <a href="/library/books" class="btn btn-primary">Quay lại danh sách sách</a>
            </div>
        </t>
    </template>
</odoo>