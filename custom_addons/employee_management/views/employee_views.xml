<odoo>
    <record id="view_employee_tree" model="ir.ui.view">
        <field name="name">employee.management.list</field>
        <field name="model">employee.management</field>
        <field name="arch" type="xml">
            <list string="Danh Sách Nhân Viên">
                <field name="name"/>
                <field name="age"/>
                <field name="department"/>
            </list>
        </field>
    </record>

    <record id="action_employee_list" model="ir.actions.act_window">
        <field name="name">Danh Sách Nhân Viên</field>
        <field name="res_model">employee.management</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>